APP_NAME="Grocery POS & Inventory System"
APP_VERSION=0.1.0
APP_ENV=development
API_ADDR=:8080
DATABASE_URL=grocery:password@tcp(127.0.0.1:3306)/grocery_pos?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-in-production
VITE_API_BASE_URL=http://localhost:8080/api
UPLOAD_DIR=storage/uploads

# Production notes:
# - Use a long random JWT_SECRET.
# - Set CORS_ORIGINS to the deployed web origin.
# - Keep DATABASE_URL on utf8mb4 so Thai text remains readable.
# - LINE token and target ID are configured in the Admin Settings page, not in this env file.
